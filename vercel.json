{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/streak-reminders",
      "schedule": "30 13 * * *"
    },
    {
      "path": "/api/cron/inactive-reminders",
      "schedule": "30 6 * * *"
    }
  ]
}
